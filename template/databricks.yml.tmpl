bundle:
  name: LiveValidator

include:
  - resources/*.yml

workspace:
  root_path: /Workspace/LiveValidator

permissions:
  - user_name: {{.deployer_email}}
    level: CAN_MANAGE

resources:
  apps:
    live_validator:
      name: live-validator
      description: Compare tables or query results across systems
      source_code_path: src/app
      permissions:
        - level: CAN_USE
          group_name: users
      resources:
        - name: postgres
          database:
            database_name: databricks_postgres
            instance_name: ${resources.database_instances.live_validator_database.name}
            permission: CAN_CONNECT_AND_CREATE

  database_instances:
    live_validator_database:
      name: live-validator
      enable_pg_native_login: true
      capacity: CU_1

  database_catalogs:
    live_validator_catalog:
      database_instance_name: ${resources.database_instances.live_validator_database.name}
      name: live_validator
      database_name: databricks_postgres
      create_database_if_not_exists: true

  clusters:
    live_validator_cluster:
      cluster_name: live-validator
{{- if eq .cloud "aws"}}
      node_type_id: i3.2xlarge
      driver_node_type_id: i3.2xlarge
      aws_attributes:
        availability: ON_DEMAND
{{- else if eq .cloud "azure"}}
      node_type_id: Standard_DS4_v2
      driver_node_type_id: Standard_DS4_v2
      azure_attributes:
        availability: ON_DEMAND_AZURE
{{- else if eq .cloud "gcp"}}
      node_type_id: n2-standard-8
      driver_node_type_id: n2-standard-8
      gcp_attributes:
        availability: ON_DEMAND_GCP
{{- end}}
      autoscale:
        min_workers: 1
        max_workers: 8
      spark_version: 15.4.x-scala2.12
      autotermination_minutes: 0
      enable_local_disk_encryption: false
      data_security_mode: USER_ISOLATION
      runtime_engine: PHOTON

targets:
  {{.target_name}}:
    default: true
    mode: production
    workspace:
      host: {{.workspace_host}}
      root_path: /Workspace/LiveValidator
    permissions:
      - level: CAN_MANAGE
        group_name: {{.admin_group}}
      - level: CAN_RUN
        group_name: users
    resources:
      clusters:
        live_validator_cluster:
          permissions:
            - group_name: users
              level: CAN_ATTACH_TO
            - group_name: {{.admin_group}}
              level: CAN_MANAGE
      jobs:
        run_validation:
          permissions:
            - level: CAN_MANAGE
              group_name: {{.admin_group}}
